# Root environment variables
NODE_ENV=development

# Database
DATABASE_URL="postgresql://app_user:app_password@localhost:5432/fitness_app?schema=public"

# API
PORT=3001
CORS_ORIGIN=true
TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
TELEGRAM_MINIAPP_URL=https://your-miniapp-url.example
TELEGRAM_BOT_POLLING_ENABLED=false
SESSION_SECRET=replace_with_strong_random_secret
ALLOW_INSECURE_TELEGRAM_AUTH=false

# Miniapp
VITE_API_BASE_URL=http://localhost:3001
VITE_ALLOW_DEV_TELEGRAM_AUTH=false
