# Root environment variables
NODE_ENV=development

# Database
DATABASE_URL="postgresql://app_user:app_password@localhost:5432/fitness_app?schema=public"

# API
PORT=3001
CORS_ORIGIN=true
TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
TELEGRAM_MINIAPP_URL=https://your-miniapp-url.example
TELEGRAM_BOT_POLLING_ENABLED=false
SESSION_SECRET=replace_with_strong_random_secret
ALLOW_INSECURE_TELEGRAM_AUTH=false

# Miniapp
VITE_API_BASE_URL=http://localhost:3001
VITE_ALLOW_DEV_TELEGRAM_AUTH=false

# URL strategy planning (Phase 7.7, no deploy yet)
# Stable public URL used in BotFather mini app button.
MINIAPP_PUBLIC_URL=https://miniapp.example.com
# Public API URL used by mini app frontend.
API_PUBLIC_URL=https://api.example.com
# Internal API URL for infrastructure-to-infrastructure traffic (optional).
API_INTERNAL_URL=http://api:3001

# Environment promotion plan examples:
# MINIAPP_PUBLIC_URL_DEV=https://miniapp-dev.example.com
# MINIAPP_PUBLIC_URL_STAGE=https://miniapp-stage.example.com
# MINIAPP_PUBLIC_URL_PROD=https://miniapp.example.com
# API_PUBLIC_URL_DEV=https://api-dev.example.com
# API_PUBLIC_URL_STAGE=https://api-stage.example.com
# API_PUBLIC_URL_PROD=https://api.example.com
